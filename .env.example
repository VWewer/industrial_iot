# ============================================================
# Industrial IoT Demo -- Root configuration
# ============================================================
# This file is the CANONICAL SOURCE OF TRUTH for all service
# ports and shared infrastructure settings.
#
# Every WP .env.example inherits port values from here.
# Every WP README cites these as the authoritative port numbers.
# The Level 3 harmony check (P-13) cross-references this file.
#
# Usage:
#   cp .env.example .env
#   # For WP5 (Snowflake): also fill in the Snowflake credentials below
#
# For new contributors:
#   All WPs except WP5 work with defaults -- no changes needed.
#   WP5 requires real Snowflake credentials (see WP5 section below).
# ============================================================

# ---- MQTT broker ----
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# ---- Service ports (canonical -- do not change without updating ALL WP configs) ----
# WP1 sensor sim control API
# NOTE: port 8000 is excluded by Windows on most machines. Use 8080 natively.
#       Docker compose uses 8000 internally (no Windows exclusion in containers).
WP1_CONTROL_PORT=8080

# WP2 SIMATIC mock
WP2_SIMATIC_PORT=8001

# WP3 Mendix mock
WP3_MENDIX_PORT=8002

# WP4 SAP mock
WP4_SAP_PORT=8003

# WP5 Snowflake layer
WP5_API_PORT=8005

# WP7 Unified cockpit (Streamlit default)
WP7_COCKPIT_PORT=8501

# ---- Project identifiers ----
PLANT_ID=regensburg
OVEN_ID=oven-01

# ---- Demo timing ----
# 60x compression means a 480-min cycle completes in ~8 real minutes
CYCLE_COMPRESSION_FACTOR=60
SAP_PULL_INTERVAL_S=60
TRANSFORM_INTERVAL_S=30

# ============================================================
# WP5 -- Snowflake credentials (required for WP5 only)
# ============================================================
# Obtain from your Snowflake account admin.
# Account identifier format: <orgname>-<account_name> or <account>.<region>
# See: https://docs.snowflake.com/en/user-guide/admin-account-identifier
#
# Other contributors who do not have Snowflake credentials:
#   - WP1-WP4 and WP7 work without these fields.
#   - WP5 will print a clear error listing the missing vars and exit.
#   - Use docker-compose profiles to start only the services you need.
# ============================================================
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_DATABASE=INDUSTRIAL_IOT_DEMO
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN
