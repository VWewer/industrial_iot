# ============================================================
# Industrial IoT Demo -- Root configuration
# ============================================================
# CANONICAL SOURCE OF TRUTH for service ports and shared
# infrastructure settings. Machine-readable counterpart to the
# port table in architecture_handover.md Section 0a.
#
# Scope: ports and shared config ONLY. No credentials here.
# WP-specific credentials (e.g. Snowflake) go in the WP's own
# .env file -- see wp5-snowflake-layer/.env.example.
#
# Usage:
#   cp .env.example .env          (already done if you followed setup)
#   # No further changes needed for WP1-WP4 and WP7.
#   # For WP5: copy wp5-snowflake-layer/.env.example to
#   #          wp5-snowflake-layer/.env and fill in credentials.
# ============================================================

# ---- MQTT broker ----
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# ---- Service ports (do not change without updating ALL WP configs) ----
# WP1 control API -- 8080 on Windows native (8000 excluded by OS)
#                    8000 in Docker (no Windows exclusion in containers)
WP1_CONTROL_PORT=8080

# WP2 SIMATIC mock
WP2_SIMATIC_PORT=8001

# WP3 Mendix mock
WP3_MENDIX_PORT=8002

# WP4 SAP mock
WP4_SAP_PORT=8003

# WP5 Snowflake layer
WP5_API_PORT=8005

# WP7 Unified cockpit (Streamlit default)
WP7_COCKPIT_PORT=8501

# ---- Project identifiers ----
PLANT_ID=regensburg
OVEN_ID=oven-01

# ---- Demo timing ----
# 60x compression: a 480-min drying cycle completes in ~8 real minutes
CYCLE_COMPRESSION_FACTOR=60
SAP_PULL_INTERVAL_S=60
TRANSFORM_INTERVAL_S=30
