MQTT_BROKER_HOST=localhost          # MQTT broker hostname
MQTT_BROKER_PORT=1883               # MQTT broker port
SIMATIC_API_PORT=8001               # FastAPI port for WP2
HISTORIAN_MAX_READINGS_PER_CHANNEL=500  # Circular buffer depth per (oven, sensor) channel
MOISTURE_THRESHOLD_PPM=500          # Moisture value below which cycle_complete is inferred
MAX_CYCLE_MINUTES=600               # Elapsed minutes beyond which status becomes timeout
PLANT_ID=regensburg                 # Plant filter for MQTT topic subscription
OVEN_ID=oven-01                     # Oven identifier
LOG_LEVEL=INFO
