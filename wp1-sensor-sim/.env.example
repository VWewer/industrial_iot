# MQTT broker connection
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Sensor publish cadence (real seconds between readings per sensor)
SENSOR_PUBLISH_INTERVAL_S=5

# Oven identity
PLANT_ID=regensburg
OVEN_ID=oven-01

# Time compression: 1.0 = real time, 60.0 = 1 simulated hour per real minute
# Demo default: 60.0 (full 8-hour cycle completes in ~8 real minutes)
CYCLE_TIME_COMPRESSION=60.0

# Control API port
CONTROL_API_PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
