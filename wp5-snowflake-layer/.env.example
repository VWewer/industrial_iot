# WP5 -- Snowflake Data Layer
# Copy this file to .env and fill in your values.
# Port and shared config canonical source: ../.env.example (project root)
#
# --- Snowflake (required) ---
# Obtain from your Snowflake account admin.
# If any of these are missing, WP5 will exit at startup with a clear error.
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_DATABASE=INDUSTRIAL_IOT_DEMO
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# --- MQTT ---
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# --- Upstream services ---
SAP_API_URL=http://localhost:8003

# --- Timing ---
SAP_PULL_INTERVAL_S=60
TRANSFORM_INTERVAL_S=30

# --- API ---
WP5_API_PORT=8005

# --- Seed data ---
# Set to false after first run to skip reloading historical cycles
LOAD_SEED_DATA=true
